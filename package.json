{
  "name": "sc-agent-cli",
  "version": "0.5.0",
  "description": "Provider-agnostic CLI agent with tool use, compatible with any OpenAI-compatible API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "sc": "bin/sc.js"
  },
  "scripts": {
    "prepare": "husky",
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node bin/sc.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "lint-staged": {
    "*.ts": [
      "vitest run --reporter=verbose --changed"
    ]
  },
  "keywords": [
    "agent",
    "cli",
    "ai",
    "llm",
    "openai",
    "ollama",
    "anthropic"
  ],
  "author": "Sergio Canales",
  "license": "Apache-2.0",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "diff": "^5.2.0",
    "fast-glob": "^3.3.0",
    "ignore": "^5.3.0",
    "marked": "^15.0.11",
    "marked-terminal": "^7.3.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/diff": "^5.2.0",
    "@types/node": "^22.0.0",
    "@types/prompts": "^2.4.9",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
