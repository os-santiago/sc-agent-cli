{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "description": "Example project-local config for SC-Agent CLI",
  "model": {
    "provider": "openai-compatible",
    "baseUrl": "http://localhost:11434/v1",
    "model": "llama3.2",
    "temperature": 0.7,
    "maxTokens": 4096,
    "stream": true
  },
  "permissions": {
    "autoApprove": [
      "read_file",
      "list_dir",
      "search_text"
    ],
    "denyPaths": [
      ".env",
      ".env.*",
      "**/*.key",
      "**/*.pem",
      "**/*.secret"
    ]
  }
}
