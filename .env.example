# SC CLI Environment Variables
# Copy this file to .env and fill in your API keys
# Or export these variables in your shell

# General API key (highest priority)
# SC_API_KEY="your-api-key-here"

# OpenAI API key
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY="sk-your-openai-key-here"

# Anthropic API key
# Get from: https://console.anthropic.com/
# ANTHROPIC_API_KEY="sk-ant-your-anthropic-key-here"

# NVIDIA API key
# Get from: https://build.nvidia.com/
# NVIDIA_API_KEY="nvapi-your-nvidia-key-here"

# Behavior configuration
# Maximum iterations before agent stops (default: 100)
# SC_MAX_ITERATIONS=100

# Maximum storage in gigabytes for persistent data (default: 1)
# Auto-cleanup removes oldest files when limit is exceeded
# SC_MAX_STORAGE_GB=1

# Note: Environment variables take precedence over config file keys
# Priority: SC_API_KEY > provider-specific keys > config file

# WOS (Workspace Operating System) Integration
# Enable reporting to WOS Hub for monitoring
# WOS_ENABLED=true
# WOS_HUB_URL=http://localhost:4000
# WOS_SECRET=your-secret-here
